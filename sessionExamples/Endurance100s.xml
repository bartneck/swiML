<?xml version="1.0" encoding="UTF-8"?>
<program xmlns="https://github.com/bartneck/swiML"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/bartneck/swiML https://raw.githubusercontent.com/bartneck/swiML/main/version/latest/swiML.xsd">
    <title>Endurance 100s</title>
    <author>
        <firstName>Morgan</firstName>
        <lastName>Lee</lastName>
    </author>
    <creationDate>2026-04-23</creationDate>    
    <poolLength>25</poolLength>
    <lengthUnit>meters</lengthUnit>
    <hideIntro>false</hideIntro>
    <layoutWidth>75</layoutWidth>
    
    <instruction>
        <segmentName>Warm Up</segmentName>
    </instruction>
    <instruction>
        <repetition>
            <repetitionCount>4</repetitionCount>
            <instruction>
                <length><lengthAsDistance>50</lengthAsDistance></length>
                <stroke><drill>
                        <drillName>any</drillName>
                        <drillStroke>freestyle</drillStroke>
                </drill></stroke>
            </instruction>
            <instruction>
                <length><lengthAsDistance>50</lengthAsDistance></length>
                <stroke><standardStroke>freestyle</standardStroke></stroke>
            </instruction>
        </repetition>
    </instruction>
    <instruction>
        <length><lengthAsDistance>100</lengthAsDistance></length>
        <stroke><kicking><standardKick>freestyle</standardKick></kicking></stroke>
    </instruction>
    
    <instruction><segmentName>Main Set</segmentName></instruction>
    <instruction>
        <repetition>
            <repetitionCount>15</repetitionCount>
            <instruction>
                <length><lengthAsDistance>100</lengthAsDistance></length>
                <stroke><standardStroke>freestyle</standardStroke></stroke>
                <rest><afterStop>PT0M10S</afterStop></rest>
                <intensity>
                    <startIntensity><zone>endurance</zone></startIntensity>
                </intensity>
            </instruction>
        </repetition>
    </instruction>
    
    <instruction><segmentName>Cool Down</segmentName></instruction>
    <instruction>
        <length><lengthAsDistance>200</lengthAsDistance></length>
        <stroke><standardStroke>freestyle</standardStroke></stroke>
        <intensity>
            <startIntensity><zone>easy</zone></startIntensity>
        </intensity>
    </instruction>
    
</program>