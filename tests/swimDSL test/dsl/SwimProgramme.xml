<?xml version="1.0" encoding="UTF-8"?>
<program xmlns="https://github.com/bartneck/swiML" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://github.com/bartneck/swiML https://raw.githubusercontent.com/bartneck/swiML/main/version/latest/swiML.xsd">
  <title>Demo Program of today</title>
  <author>
    <firstName>Christoph</firstName>
    <lastName>Bartneck</lastName>
  </author>
  <programDescription>Demo of the swimDSL editor. It shows all the major funactions</programDescription>
  <creationDate>2026-01-27</creationDate>
  <poolLength>25</poolLength>
  <lengthUnit>meters</lengthUnit>
  <instruction>
    <segmentName>Warm up</segmentName>
  </instruction>
  <instruction>
    <length>
      <lengthAsDistance>400</lengthAsDistance>
    </length>
    <stroke>
      <standardStroke>any</standardStroke>
    </stroke>
  </instruction>
  <instruction>
    <repetition>
      <repetitionCount>8</repetitionCount>
        <instruction>
          <length>
            <lengthAsDistance>50</lengthAsDistance>
          </length>
          <stroke>
            <standardStroke>freestyle</standardStroke>
          </stroke>
          <rest>
            <sinceStart>PT1M</sinceStart>
          </rest>
          <intensity>
            <startIntensity>
              <percentageEffort>60</percentageEffort>
            </startIntensity>
          </intensity>
        </instruction>
    </repetition>
  </instruction>
  <instruction>
    <segmentName>Main program</segmentName>
  </instruction>
  <instruction>
    <repetition>
      <repetitionCount>4</repetitionCount>
      <instruction>
        <length>
          <lengthAsDistance>100</lengthAsDistance>
        </length>
        <stroke>
          <standardStroke>freestyle</standardStroke>
        </stroke>
        <rest>
          <sinceStart>PT1M45S</sinceStart>
        </rest>
        <intensity>
          <startIntensity>
            <percentageEffort>60</percentageEffort>
          </startIntensity>
        </intensity>
      </instruction>
      <instruction>
        <repetition>
          <repetitionCount>2</repetitionCount>
          <instruction>
            <length>
              <lengthAsDistance>50</lengthAsDistance>
            </length>
            <stroke>
              <standardStroke>backstroke</standardStroke>
            </stroke>
            <rest>
              <sinceStart>PT1M</sinceStart>
            </rest>
            <intensity>
              <startIntensity>
                <percentageEffort>90</percentageEffort>
              </startIntensity>
            </intensity>
          </instruction>
        </repetition>
      </instruction>
    </repetition>
  </instruction>
  <instruction>
    <length>
      <lengthAsDistance>200</lengthAsDistance>
    </length>
    <stroke>
      <standardStroke>freestyle</standardStroke>
    </stroke>
    <equipment>pads</equipment>
    <equipment>pullBuoy</equipment>
  </instruction>
  <instruction>
    <segmentName>Warm down</segmentName>
  </instruction>
  <instruction>
    <length>
      <lengthAsDistance>100</lengthAsDistance>
    </length>
    <stroke>
      <standardStroke>any</standardStroke>
    </stroke>
  </instruction>
</program>