<?xml version="1.0" encoding="UTF-8"?>

<program xmlns="https://github.com/bartneck/swiML"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/bartneck/swiML https://raw.githubusercontent.com/bartneck/swiML/main/version/latest/swiML.xsd">
    <title>Jasi Masters</title>
    <author>
        <firstName>Morgan</firstName>
        <lastName>Lee</lastName>
    </author>
    <creationDate>2026-04-05</creationDate>    
    <poolLength>25</poolLength>
    <lengthUnit>meters</lengthUnit>
    <hideIntro>false</hideIntro>
    <layoutWidth>75</layoutWidth>
    
    <!-- 400 Loosen -->
    <instruction>
        <length><lengthAsDistance>400</lengthAsDistance></length>
        <stroke><standardStroke>any</standardStroke></stroke>
        <instructionDescription>loosen</instructionDescription>
    </instruction>
    
    <!-- 300 k/d/s as 100s 50free 50 choice -->
    <instruction>
        <continue>
            <!-- 1st 100 -->
            <instruction>
                <continue>
                    <instruction>
                        <length><lengthAsDistance>50</lengthAsDistance></length>
                        <stroke><kicking><standardKick>freestyle</standardKick></kicking></stroke>
                    </instruction>
                    <instruction>
                        <length><lengthAsDistance>50</lengthAsDistance></length>
                        <stroke><kicking><standardKick>any</standardKick></kicking></stroke>
                    </instruction>
                </continue>
            </instruction>
            <!-- 2nd 100 -->
            <instruction>
                <continue>
                    <instruction>
                        <length><lengthAsDistance>50</lengthAsDistance></length>
                        <stroke><drill>
                                <drillName>any</drillName>
                                <drillStroke>freestyle</drillStroke>
                        </drill></stroke>
                    </instruction>
                    <instruction>
                        <length><lengthAsDistance>50</lengthAsDistance></length>
                        <stroke><drill>
                                <drillName>any</drillName>
                                <drillStroke>any</drillStroke>
                        </drill></stroke>
                    </instruction>
                </continue>
            </instruction>
            <!-- 3rd 100 -->
            <instruction>
                <continue>
                    <instruction>
                        <length><lengthAsDistance>50</lengthAsDistance></length>
                        <stroke><standardStroke>freestyle</standardStroke></stroke>
                    </instruction>
                    <instruction>
                        <length><lengthAsDistance>50</lengthAsDistance></length>
                        <stroke><standardStroke>any</standardStroke></stroke>
                    </instruction>
                </continue>
            </instruction>
        </continue>
    </instruction>
    
    <!-- 200 k/scull/d/s as 25s choice -->
    <instruction>
        <continue>
            <instruction>
                <repetition>
                    <repetitionCount>4</repetitionCount>
                    <instruction>
                        <continue>
                            <instruction>
                                <length><lengthAsDistance>25</lengthAsDistance></length>
                                <stroke><kicking><standardKick>any</standardKick></kicking></stroke>
                            </instruction>
                            <instruction>
                                <length><lengthAsDistance>25</lengthAsDistance></length>
                                <stroke><drill>
                                        <drillName>scull</drillName>
                                        <drillStroke>any</drillStroke>
                                </drill></stroke>
                            </instruction>
                            <instruction>
                                <length><lengthAsDistance>25</lengthAsDistance></length>
                                <stroke><drill>
                                        <drillName>any</drillName>
                                        <drillStroke>any</drillStroke>
                                </drill></stroke>
                            </instruction>
                            <instruction>
                                <length><lengthAsDistance>25</lengthAsDistance></length>
                                <stroke><standardStroke>any</standardStroke></stroke>
                            </instruction>
                        </continue>
                    </instruction>
                </repetition>
            </instruction>
        </continue>
    </instruction>
    
    <!-- 300 Free P+P @45s rest -->
    <instruction>
        <length><lengthAsDistance>300</lengthAsDistance></length>
        <stroke><standardStroke>freestyle</standardStroke></stroke>
        <rest><afterStop>PT0M45S</afterStop></rest>
        <equipment>pads</equipment>
        <equipment>pullBuoy</equipment>
    </instruction>
    
    <!-- 200 Free @30s rest -->
    <instruction>
        <length><lengthAsDistance>200</lengthAsDistance></length>
        <stroke><standardStroke>freestyle</standardStroke></stroke>
        <rest><afterStop>PT0M30S</afterStop></rest>
    </instruction>
    
    <!-- 100 Free -->
    <instruction>
        <length><lengthAsDistance>100</lengthAsDistance></length>
        <stroke><standardStroke>freestyle</standardStroke></stroke>
    </instruction>
    
    <!-- 2x50 Free (Paddles?) Fast @60s -->
    <instruction>
        <repetition>
            <repetitionCount>2</repetitionCount>
            <instruction>
                <length><lengthAsDistance>50</lengthAsDistance></length>
                <stroke><standardStroke>freestyle</standardStroke></stroke>
                <rest><sinceStart>PT1M0S</sinceStart></rest>
                <intensity>
                    <startIntensity><percentageEffort>85</percentageEffort></startIntensity>
                </intensity>
            </instruction>
        </repetition>
    </instruction>
    
    <!-- 200 kick fins -->
    <instruction>
        <length><lengthAsDistance>200</lengthAsDistance></length>
        <stroke><kicking><standardKick>any</standardKick></kicking></stroke>
        <equipment>fins</equipment>
    </instruction>
    
    <!-- 4x50 IM Kick @5s rest -->
    <instruction>
        <repetition>
            <repetitionCount>4</repetitionCount>
            <rest><afterStop>PT0M5S</afterStop></rest>
            <instruction>
                <length><lengthAsDistance>50</lengthAsDistance></length>
                <stroke><kicking><standardKick>individualMedley</standardKick></kicking></stroke>
            </instruction>
        </repetition>
    </instruction>
    
    <!-- 4x25 Fins @60 -->
    <instruction>
        <repetition>
            <repetitionCount>4</repetitionCount>
            <instruction>
                <length><lengthAsDistance>25</lengthAsDistance></length>
                <stroke><standardStroke>any</standardStroke></stroke>
                <rest><sinceStart>PT1M0S</sinceStart></rest>
                <intensity><startIntensity><percentageEffort>100</percentageEffort></startIntensity></intensity>
                <equipment>fins</equipment>
            </instruction>
        </repetition>
    </instruction>
    
    <!-- 200 Free P+P -->
    <instruction>
        <length><lengthAsDistance>200</lengthAsDistance></length>
        <stroke><standardStroke>freestyle</standardStroke></stroke>
        <equipment>pullBuoy</equipment>
        <equipment>pads</equipment>
    </instruction>
    
    <!-- 4x50 IMO @65s -->
    <instruction>
        <repetition>
            <repetitionCount>4</repetitionCount>
            <instruction>
                <length><lengthAsDistance>50</lengthAsDistance></length>
                <stroke><standardStroke>individualMedleyOrder</standardStroke></stroke>
                <rest><sinceStart>PT1M5S</sinceStart></rest>
            </instruction>
        </repetition>
    </instruction>
    
    <!-- 4x25 best stroke fast @60s -->
    <instruction>
        <repetition>
            <repetitionCount>4</repetitionCount>
            <instruction>
                <length><lengthAsDistance>25</lengthAsDistance></length>
                <stroke><standardStroke>nr1</standardStroke></stroke>
                <rest><sinceStart>PT1M0S</sinceStart></rest>
                <intensity>
                    <startIntensity><percentageEffort>95</percentageEffort></startIntensity>
                </intensity>
            </instruction>
        </repetition>
    </instruction>
    
</program>