<?xml version="1.0" encoding="UTF-8"?>
<program xmlns="https://github.com/bartneck/swiML"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/bartneck/swiML https://raw.githubusercontent.com/bartneck/swiML/main/version/latest/swiML.xsd">
    <title>Jasi Masters</title>
    <author>
        <firstName>Morgan</firstName>
        <lastName>Lee</lastName>
    </author>
    <creationDate>2026-04-12</creationDate>    
    <poolLength>25</poolLength>
    <lengthUnit>meters</lengthUnit>
    <hideIntro>false</hideIntro>
    <layoutWidth>75</layoutWidth>
    
    <!-- 400 loosen -->
    <instruction>
        <length><lengthAsDistance>400</lengthAsDistance></length>
        <stroke><standardStroke>any</standardStroke></stroke>
        <instructionDescription>loosen</instructionDescription>
    </instruction>
    
    <!-- 6x75 k/d/s--> 
    <instruction>
        <repetition>
            <repetitionCount>2</repetitionCount>

                    <instruction>
                        <length><lengthAsDistance>75</lengthAsDistance></length>
                        <stroke><kicking><standardKick>freestyle</standardKick></kicking></stroke>
                    </instruction>
                    <instruction>
                        <length><lengthAsDistance>75</lengthAsDistance></length>
                        <stroke><drill>
                                <drillName>any</drillName>
                                <drillStroke>freestyle</drillStroke>
                            </drill>
                        </stroke>
                        <instructionDescription>6kick, 123, fingertrail</instructionDescription>
                    </instruction>
                    <instruction>
                        <length><lengthAsDistance>75</lengthAsDistance></length>
                        <stroke><standardStroke>freestyle</standardStroke></stroke>
                    </instruction>
                
        </repetition>
    </instruction>
    
    <!-- 6x100 Free build 1-6-->
    <instruction>
        <repetition>
            <repetitionCount>6</repetitionCount>
            <instruction>
                <length><lengthAsDistance>100</lengthAsDistance></length>
                <stroke><standardStroke>freestyle</standardStroke></stroke>
                <instructionDescription>Build 1-6</instructionDescription>
            </instruction>
        </repetition>
    </instruction>
    
    <!-- 6x50 Free P+P b5 -->
    <instruction>
        <repetition>
            <repetitionCount>6</repetitionCount>
            <instruction>
                <length><lengthAsDistance>50</lengthAsDistance></length>
                <stroke><standardStroke>freestyle</standardStroke></stroke>
                <breath>5</breath>
                <equipment>pullBuoy</equipment>
                <equipment>pads</equipment>
            </instruction>
        </repetition>
    </instruction>
    
    <!-- 6x25 free Pull MAX @45s -->
    <instruction>
        <repetition>
            <repetitionCount>6</repetitionCount>
            <instruction>
                <length><lengthAsDistance>25</lengthAsDistance></length>
                <stroke><standardStroke>freestyle</standardStroke></stroke>
                <rest><sinceStart>PT0M45S</sinceStart></rest>
                <intensity>
                    <startIntensity><zone>max</zone></startIntensity>
                </intensity>
                <equipment>pullBuoy</equipment>
            </instruction>
        </repetition>
    </instruction>
    
    <!-- 4x (50kob @20s rest, 25 decreasing to fast @20s rest) w/ fins -->
    <instruction>
        <repetition>
            <repetitionCount>4</repetitionCount>
            <instruction>
                <length><lengthAsDistance>50</lengthAsDistance></length>
                <stroke><kicking><standardKick>backstroke</standardKick></kicking></stroke>
                <rest><afterStop>PT0M20S</afterStop></rest>
            </instruction>
            <instruction>
                <length><lengthAsDistance>25</lengthAsDistance></length>
                <stroke><standardStroke>freestyle</standardStroke></stroke>
                <rest><afterStop>PT0M20S</afterStop></rest>
                <instructionDescription>Decreasing to fast</instructionDescription>
            </instruction>
        </repetition>
    </instruction>
    
    <!-- 2x (75free @20s rest, 25best fast @45s) -->
    <instruction>
        <repetition>
            <repetitionCount>2</repetitionCount>
            <instruction>
                <length><lengthAsDistance>75</lengthAsDistance></length>
                <stroke><standardStroke>freestyle</standardStroke></stroke>
                <rest><afterStop>PT0M20S</afterStop></rest>
            </instruction>
            <instruction>
                <length><lengthAsDistance>25</lengthAsDistance></length>
                <stroke><standardStroke>nr1</standardStroke></stroke>
                <rest><sinceStart>PT0M45S</sinceStart></rest>
                <intensity>
                    <startIntensity><percentageEffort>90</percentageEffort></startIntensity>
                </intensity>
            </instruction>
        </repetition>
    </instruction>
    
    <!-- 2x (5f0ree @60s, 25best fast @45s) -->
    <instruction>
        <repetition>
            <repetitionCount>2</repetitionCount>
            <instruction>
                <length><lengthAsDistance>50</lengthAsDistance></length>
                <stroke><standardStroke>freestyle</standardStroke></stroke>
                <rest><sinceStart>PT1M0S</sinceStart></rest>
            </instruction>
            <instruction>
                <length><lengthAsDistance>25</lengthAsDistance></length>
                <stroke><standardStroke>nr1</standardStroke></stroke>
                <rest><sinceStart>PT0M45S</sinceStart></rest>
                <intensity>
                    <startIntensity><percentageEffort>90</percentageEffort></startIntensity>
                </intensity>
            </instruction>
        </repetition>
    </instruction>
    
    <!-- 2x (25free @45s, 25best fast @45s) -->
    <instruction>
        <repetition>
            <repetitionCount>2</repetitionCount>
            <instruction>
                <length><lengthAsDistance>25</lengthAsDistance></length>
                <stroke><standardStroke>freestyle</standardStroke></stroke>
                <rest><sinceStart>PT0M45S</sinceStart></rest>
            </instruction>
            <instruction>
                <length><lengthAsDistance>25</lengthAsDistance></length>
                <stroke><standardStroke>nr1</standardStroke></stroke>
                <rest><sinceStart>PT0M45S</sinceStart></rest>
                <intensity>
                    <startIntensity><percentageEffort>90</percentageEffort></startIntensity>
                </intensity>
            </instruction>
        </repetition>
    </instruction>
    
    
</program>
